using namespace std;


int main()
{
	string word;
	while(getline(cin,word))
	{
		int left=0,right=0,left_index,right_index;
		while(right<word.size())
		{
			if(word[right]==' ')
			{
				left_index = left,right_index = right-1;
				while(left_index<=right_index)
				{
					swap(word[left_index],word[right_index]);
					left_index++;
					right_index--;
				}
				left=right+1;
				right++;
			}
			else
				right++;
		}
		left_index = left,right_index=right-1;
		while(left_index<=right_index)
		{
			swap(word[left_index],word[right_index]);
			left_index++;
			right_index--;
		}
		cout<<word<<endl;
	}
}
