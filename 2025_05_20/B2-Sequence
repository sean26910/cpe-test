#include<iostream>
#include<algorithm>
#include<stack>
#include<queue>
#include<string>
#include<vector>
#include<unordered_map>
using namespace std;


int main()
{
    int n,index=1,prev,input,diff;
    while(cin>>n)
    {
        bool is_b2 = true;
        unordered_map<int,int> stor;
        vector<int> st(n);
        for(int i=0;i<n;i++)
        {
            cin>>st[i];
            if(st[i]<1)
                is_b2 = false;
            
            if(i>0 && st[i]<st[i-1])
                is_b2 = false;
        }

        for(int i=0;i<n;i++)
        {
            for(int j=i;j<n;j++)
            {
                diff = st[j]+st[i];
                if(stor[diff]>=1)
                {
                    is_b2 = false;
                    break;
                }
                stor[diff]++;
            }
            if(!is_b2)
                break;
        }
        cout<<"Case #"<<index++<<": ";
        if(is_b2)
            cout<<"It is a B2-Sequence.\n\n";
        else
            cout<<"It is not a B2-Sequence.\n\n";
    }
}
