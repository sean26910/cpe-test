#include<iostream>
#include<algorithm>
#include<stack>
#include<queue>
#include<string>
#include<vector>
#include<unordered_map>
#include<set>
using namespace std;


int main()
{
    int n;
	while(cin>>n)
	{
		if(n==0)
			break;
		vector<vector<int>> stor(n,vector<int>(n));
		vector<int> rolsum(n);
		vector<int> colsum(n);
		vector<int> ro;
		vector<int> co;

		for(int i=0;i<n;i++)
		{
			for(int j=0;j<n;j++)
				cin>>stor[i][j];
		}

		for(int i=0;i<n;i++)
		{
			for(int j=0;j<n;j++)
			{
				rolsum[i]+=stor[i][j];
				colsum[j]+=stor[i][j];
			}
		}

		for(int i=0;i<n;i++)
		{
			if(rolsum[i]%2)
				ro.push_back(i);
			if(colsum[i]%2)
				co.push_back(i);
		}

		if(ro.empty() && co.empty())
			cout<<"OK\n";
		else if(ro.size()==1 && co.size()==1)
			cout<<"Change bit ("<<ro[0]+1<<","<<co[0]+1<<")\n";
		else
			cout<<"Corrupt\n";
	}
}
